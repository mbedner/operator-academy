{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Operator Academy",
  "version": "0.1.0",
  "identifier": "com.operatoracademy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Operator Academy",
        "width": 1280,
        "height": 840,
        "minWidth": 1080,
        "minHeight": 720,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
